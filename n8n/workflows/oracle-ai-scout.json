        "jsCode": "const prompt = $json.prompt ?? '';\nconst compactTask = prompt.length > 140 ? prompt.slice(0, 137) + '...' : prompt;\nreturn {\n  json: {\n    ...$json,\n    task: compactTask,\n    thought: 'SCOUT reviso el pedido y produjo una salida corta y accionable.',\n    message: 'SCOUT recomienda ejecutar un frente puntual alineado con su especialidad.',\n    findings: [\n      'SCOUT detecto una oportunidad clara vinculada al pedido',\n      'SCOUT sugiere mantener foco en una sola decision por iteracion',\n    ],\n    risks: [\n      'SCOUT marco una dependencia o supuesto a validar',\n    ],\n    nextSteps: [\n      'SCOUT propone un siguiente paso corto y medible',\n      'Cerrar con sintesis desde ARIA',\n    ],\n    latencyMs: 900,\n  },\n};"
      },
